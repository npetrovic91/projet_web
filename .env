# ============================================================
# .env.example — Autosav / projet_web
# Copier ce fichier en .env et remplir les valeurs réelles
# CE FICHIER est versionné — .env ne l'est JAMAIS
# ============================================================

# ──────────────────────────────────────────────────────────
# APPLICATION
# ──────────────────────────────────────────────────────────
APP_ENV=production
APP_NAME=Autosav
APP_URL=https://devnenad.fr
APP_VERSION=1.0.0
APP_DEBUG=false
APP_TIMEZONE=Europe/Paris
APP_LOCALE=fr

# Clé secrète application (générer avec : php -r "echo bin2hex(random_bytes(32));")
APP_KEY=CHANGEME_32_BYTES_HEX_KEY

# ──────────────────────────────────────────────────────────
# BASE DE DONNÉES
# ──────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=CHANGEME_db_name
DB_USER=CHANGEME_db_user
DB_PASS=CHANGEME_db_password
DB_CHARSET=utf8mb4

# ──────────────────────────────────────────────────────────
# SESSIONS
# ──────────────────────────────────────────────────────────
SESSION_LIFETIME=7200
SESSION_SECURE=true
SESSION_SAMESITE=Strict

# ──────────────────────────────────────────────────────────
# MAIL (SMTP Hostinger)
# ──────────────────────────────────────────────────────────
MAIL_FROM=noreply@devnenad.fr
MAIL_FROM_NAME=Autosav
MAIL_REPLY_TO=support@devnenad.fr
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_ENCRYPT=tls
MAIL_USERNAME=noreply@devnenad.fr
MAIL_PASSWORD=CHANGEME_smtp_password
MAIL_ADMIN=admin@devnenad.fr

# ──────────────────────────────────────────────────────────
# SÉCURITÉ
# ──────────────────────────────────────────────────────────
# Durée de vie des tokens CSRF (secondes)
CSRF_TOKEN_TTL=3600

# Rate limiting : tentatives login avant blocage IP
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_WINDOW=900

# Durée de blocage IP en minutes
IP_BLOCK_DURATION=60

# Durée de validité token reset password (minutes)
PASSWORD_RESET_TTL=60

# ──────────────────────────────────────────────────────────
# LOGS
# ──────────────────────────────────────────────────────────
LOG_CHANNEL=file
LOG_LEVEL=warning
LOG_MAX_FILES=30

# ──────────────────────────────────────────────────────────
# MAINTENANCE
# ──────────────────────────────────────────────────────────
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=Application en maintenance. Revenez dans quelques instants.

# ──────────────────────────────────────────────────────────
# RGPD
# ──────────────────────────────────────────────────────────
# Durée de rétention des logs d'audit (jours)
AUDIT_LOG_RETENTION_DAYS=365

# Durée de rétention des sessions révoquées (jours)
SESSION_REVOKED_RETENTION_DAYS=90
