# ==============================================================
# AUTOSAV — .htaccess PUBLIC
# Emplacement : public_html/public/.htaccess
#
# Role : Servir les assets statiques directement.
# public/index.php est appele par root/index.php (require),
# pas par un rewrite Apache — ce fichier est donc un filet
# de securite pour les acces directs residuels.
# ==============================================================

Options -Indexes
Options -MultiViews

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /public/

    # Assets statiques → servis directement
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Tout le reste → index.php (filet de securite)
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# Compression GZIP
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml font/woff2
</IfModule>

# Cache navigateur
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css               "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png              "access plus 1 year"
    ExpiresByType image/jpeg             "access plus 1 year"
    ExpiresByType image/webp             "access plus 1 year"
    ExpiresByType image/svg+xml          "access plus 1 year"
    ExpiresByType image/x-icon           "access plus 1 year"
    ExpiresByType font/woff2             "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    Header always unset X-Powered-By
</IfModule>
